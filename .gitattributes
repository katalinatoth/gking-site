# Track PDFs with Git LFS
static/files/*.pdf filter=lfs diff=lfs merge=lfs -text
static/files/*.zip filter=lfs diff=lfs merge=lfs -text
static/files/*.shtml filter=lfs diff=lfs merge=lfs -text
static/files/*.pdf !text !filter !merge !diff
static/files/*.zip !text !filter !merge !diff
static/files/*.shtml !text !filter !merge !diff
