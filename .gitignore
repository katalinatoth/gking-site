data/citation_audit_report.json
# Generated by scripts/fill_publication_from_doi.py
data/publication_doi_fill_report.json
# Generated by scripts/intake_publication.py during local manual runs
# (the workflow writes to /tmp/, so prod is unaffected).
data/_intake_report*.json

scripts/__pycache__/

# Local venv for one-off scripts (e.g. pip install -r scripts/requirements-mojibake.txt)
.venv-fix/
