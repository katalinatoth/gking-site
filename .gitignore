# Hugo build output
public/
resources/_gen/

# OS files
.DS_Store
Thumbs.db
.Rhistory

# Node modules
node_modules/

# Scraped data (large, not needed for Hugo build)
../scraped_data/

# Hugo temporary
.hugo_build.lock

# Generated short-URL redirect stubs (source of truth is the redirects YAML).
# _automation/scripts/build_redirects.py rebuilds these at deploy time.
redirects/content/
EditMe/Redirects/content/
_site/static/_redirects

# Generated local citation audit
# (regenerate: python3 writings/scripts/audit_writings_citations.py)
writings/data/citation_audit_report.json
EditMe/Writings/Data/citation_audit_report.json
# Generated by writings/scripts/fill_publication_from_doi.py
writings/data/publication_doi_fill_report.json
EditMe/Writings/Data/publication_doi_fill_report.json
# Generated by writings/scripts/intake_publication.py during local manual runs
# (the workflow writes to /tmp/, so prod is unaffected).
writings/data/_intake_report*.json
EditMe/Writings/Data/_intake_report*.json

# Python caches
**/__pycache__/

# Local venv for one-off scripts
# (e.g. pip install -r _automation/scripts/requirements-mojibake.txt)
.venv-fix/
